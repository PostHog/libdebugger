# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Anything already in your shell env will win over what's set here.

# Project API key (phc_...). When set, libdebugger routes probe
# captures through the SDK to your PostHog. Leave blank to run in
# local-only mode where captures pretty-print to stderr.
POSTHOG_PROJECT_API_KEY=

# Personal API key (phx_...). Required for control-plane polling — the
# manager fetches the active ProgramList from /api/projects/@current/
# live_debugger/programs/active every poll_interval. Leave blank to
# run only the hand-written probes in probes.py.
POSTHOG_PERSONAL_API_KEY=

# PostHog host. Default is US cloud. For self-hosted or a local dev
# instance, point this at your server (e.g. http://localhost:8000).
POSTHOG_HOST=https://us.i.posthog.com

# Optional: tweak libdebugger's log level (DEBUG to see probe-skip
# breadcrumbs, INFO/WARNING to keep things quiet).
LIBDEBUGGER_LOG_LEVEL=INFO
